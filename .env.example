# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.
# Used by the library, CLI, and notebooks — AND by the web app (docker compose reads this same file).

# Ollama Cloud (https://ollama.com) — the example LLM system and the judge.
OLLAMA_API_KEY=your-ollama-cloud-key-here
OLLAMA_HOST=https://ollama.com

# OpenRouter (https://openrouter.ai) — only for embedding-based retrieval (e.g. the seeded RAG study).
OPENROUTER_API_KEY=your-openrouter-key-here
